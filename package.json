{
  "name": "my-report-finance",
  "productName": "My Report Finance",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env ELECTRON=true vite",
    "electron:build": "cross-env ELECTRON=true vite build && electron-builder",
    "electron:build:mac": "cross-env ELECTRON=true vite build && electron-builder --mac",
    "electron:build:linux": "cross-env ELECTRON=true vite build && electron-builder --linux",
    "electron:build:win": "cross-env ELECTRON=true vite build && electron-builder --win",
    "electron:publish": "cross-env ELECTRON=true vite build && electron-builder --publish always"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron"]
  },
  "dependencies": {
    "axios": "^1.13.6",
    "clsx": "^2.0.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.8"
  }
}
